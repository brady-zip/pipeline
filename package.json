{
  "name": "pipeline",
  "version": "1.1.0",
  "description": "CLI tool to selectively enable GitHub Actions jobs for isolated testing",
  "type": "module",
  "bin": {
    "pipeline": "./bin/pipeline"
  },
  "scripts": {
    "build": "bun build src/index.ts --compile --outfile bin/pipeline",
    "dev": "tsc --watch",
    "prepare": "husky",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "glob": "^11.0.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@types/bun": "^1.3.8",
    "@types/node": "^22.10.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "node": "^22.22.0",
    "oxlint": "^1.43.0",
    "prettier": "^3.8.1",
    "prettier-plugin-packagejson": "^3.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  }
}
